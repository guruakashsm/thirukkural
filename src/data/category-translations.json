    "kn": {
      "1": "ಪೀಠಿಕೆ- ದೈವಸ್ತುತಿ",
      "2": "ಮಳೆಯ ಸ್ತುತಿ",
      "3": "ತೊರೆದವರ ಹಿರಿಮೆ",
      "4": "ಧರ್ಮದ ಬಲವನ್ನು ಕುರಿತು",
      "5": "ಗೃಹ ಜೀವನ ಧರ್ಮ",
      "6": "ಬಾಳ ಸಂಗಾತಿಯ ಒಳಿತು",
      "7": "ಮಕ್ಕಳನ್ನು ಪಡೆಯುವಿಕೆ",
      "8": "ಪ್ರೀತಿ ಪರತೆ",
      "9": "ಅತಿಥಿ ಸತ್ಕಾರ",
      "10": "ಸವಿಮಾತು ಅಡುವ್ದು",
      "11": "ಕೃತಜ್ಞತೆಯ ಅರಿಕೆ",
      "12": "ಸಮದರ್ಶಿತನ",
      "13": "ಸಂಯಮ ಸಂಪನ್ನತೆ",
      "14": "ನಡತೆಯುಳ್ಳವನಾಗಿರುವುದು",
      "15": "ಪರಸ್ತ್ರೀಯರನ್ನು ಬಯಸದಿರುವುದು",
      "16": "ಸಹನ ಶೀಲತೆ",
      "17": "ಅಸೂಯೆ ಪಡದಿರುವುದು",
      "18": "ಲೋಭ ಪಡದಿರುವುದು",
      "19": "ಚಾಡಿ ಹೇಳದಿರುವುದು",
      "20": "ವ್ಯರ್ಥಲಾಪ ಮಾಡದ್ರುವುದು",
      "21": "ಕೆಟ್ಟ ಕಲಸಗಳ ಭಯ",
      "22": "ಉಪಕಾರ ತಿಳುವಳಿಕೆ",
      "23": "ಕೂಡುಗೆ",
      "24": "ಕೀರ್ತಿ",
      "25": "ಕರುಣೆ ತೋರುವುದು",
      "26": "ಮಾಂಸ ತ್ಯಜ್ಯ",
      "27": "ತಪಸ್ಸು",
      "28": "ಅನುಚಿತ ನಡೆವಳಿಕೆ",
      "29": "ಕಳದಿರುವುದು",
      "30": "ನಿಜ ಹೇಳುವುದು",
      "31": "ಕೋಪ ತಾಳದಿರುವುದು",
      "32": "ಕೆಡುಕನ್ನು ಮಾಡದಿರುವುದು",
      "33": "ಕೊಲ್ಲದಿರುವುದು",
      "34": "ನೆಲೆಯಿಲ್ಲದಿರುವುದು",
      "35": "ತೊರೆಯುವಿಕೆ",
      "36": "ನಿಜವನ್ನು ತಿಳಿತುವುದು",
      "37": "ಆಸೆಯನ್ನು ಹರಿಯುವುದು",
      "38": "ವಿಧಿ",
      "39": "ಅರಸನ ಹಿರಿಮೆ",
      "40": "ಶಿಕ್ಷಣ",
      "41": "ಅವಿದ್ಯೆ",
      "42": "ಕೇಳುವಿಕೆ",
      "43": "ಅರಿವು",
      "44": "ತಪ್ಪು",
      "45": "ಹಿರಿಯರ ಆಶ್ರೆಯ",
      "46": "ನೀಚರ ಸಹವಾಸ ಸೇರದಿರುವುದು",
      "47": "ತಿಳಿದು ವರ್ತಿಸುವ ಬಗೆ",
